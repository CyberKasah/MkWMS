<UserControl x:Class="MkWMS.Desktop.Views.UserControls.DocumentDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
        <converters:ItemSumConverter x:Key="ItemSumConverter" />
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">

        <Border Background="{StaticResource Surface}"
                CornerRadius="12"
                Padding="24"
                Effect="{StaticResource Elevation2}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding Document.Id, StringFormat='Документ №{0}', FallbackValue='Детали документа'}"
                               Style="{StaticResource HeaderText}"
                               FontSize="24"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Обновить"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="110" Height="42" Margin="0,0,12,0"/>

                        <Button Content="← Назад к списку"
                                Command="{Binding GoBackCommand}"
                                Style="{StaticResource OutlineButton}"
                                Width="160" Height="42"/>
                    </StackPanel>
                </Grid>


                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceHover}"
                        CornerRadius="10"
                        Padding="20"
                        Margin="0,16,0,20"
                        Visibility="{Binding Document, Converter={StaticResource NotNullToBool}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>


                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,40,0">
                            <TextBlock Text="Номер документа" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.DocumentNumber}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Тип документа" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.DocumentTypeName, FallbackValue='—'}" FontSize="16" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Дата создания" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.CreatedDate, StringFormat=dd.MM.yyyy HH:mm}" FontSize="16"/>
                        </StackPanel>


                        <StackPanel Grid.Row="0" Grid.Column="3">
                            <TextBlock Text="Статус" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.Status}"
                                       FontSize="16" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding Document.Status}" Value="Проведен">
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Document.Status}" Value="Черновик">
                                                <Setter Property="Foreground" Value="#F39C12"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Document.Status}" Value="Отменен">
                                                <Setter Property="Foreground" Value="#E74C3C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>


                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,16,40,0">
                            <TextBlock Text="Склад" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.WarehouseName, FallbackValue='—'}" FontSize="15"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,16,0,0">
                            <TextBlock Text="Контрагент" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.CounterpartyName, FallbackValue='—'}" FontSize="15"/>
                        </StackPanel>


                        <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Margin="0,16,0,0">
                            <TextBlock Text="Комментарий" Style="{StaticResource SubHeaderText}"/>
                            <TextBlock Text="{Binding Document.Comment, FallbackValue='—'}"
                                       TextWrapping="Wrap" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <TextBlock Grid.Row="2"
                           Text="Состав документа"
                           Style="{StaticResource SubHeaderText}"
                           FontSize="18" Margin="0,0,0,12"/>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#F7F7F7"
                          RowHeight="48"
                          CanUserResizeColumns="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="70"
                                            ElementStyle="{StaticResource CenterText}"/>

                        <DataGridTextColumn Header="Товар"
                                            Binding="{Binding ProductName}"
                                            Width="3*"/>

                        <DataGridTextColumn Header="Кол-во"
                                            Binding="{Binding Quantity, StringFormat=N2}"
                                            Width="110"
                                            ElementStyle="{StaticResource CenterText}"/>

                        <DataGridTextColumn Header="Цена"
                                            Binding="{Binding Price, StringFormat=N2}"
                                            Width="110"
                                            ElementStyle="{StaticResource CenterText}"/>


                        <DataGridTextColumn Header="Сумма"
                    Binding="{Binding ., Converter={StaticResource ItemSumConverter}}"
                    Width="130"
                    ElementStyle="{StaticResource CenterText}"/>

                        <DataGridTextColumn Header="НДС"
                    Binding="{Binding VatSum, StringFormat={}{0:N2}}"
                    Width="110"
                    ElementStyle="{StaticResource CenterText}"/>

                        <DataGridTextColumn Header="Итого с НДС"
                    Binding="{Binding ., Converter={StaticResource ItemSumConverter}, ConverterParameter=WithVat}"
                    Width="140"
                    ElementStyle="{StaticResource CenterText}"/>
                    </DataGrid.Columns>
                </DataGrid>


                <Border Grid.Row="3"
                        Background="#F8FAFC"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,20,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="ИТОГО ПО ДОКУМЕНТУ"
                                   FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Количество:"
                                       FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalQuantity, StringFormat='{}{0:N2}'}"
                                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="40,0,0,0" HorizontalAlignment="Right">
                            <TextBlock Text="Сумма с НДС:"
                                       FontSize="15" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalSum, StringFormat='{}{0:N2} ₽'}"
                                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource Primary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <StackPanel Grid.Row="4" Margin="0,16,0,0">
                    <ProgressBar Height="4"
                                 IsIndeterminate="{Binding IsLoading}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource Danger}"
                               Margin="0,8,0,0"
                               TextAlignment="Center"
                               FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>