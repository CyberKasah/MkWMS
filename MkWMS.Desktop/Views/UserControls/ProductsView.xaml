<UserControl x:Class="MkWMS.Desktop.Views.UserControls.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             xmlns:views="clr-namespace:MkWMS.Desktop.Views.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <TabControl>
            <TabItem Header="Товары">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="420"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая часть: таблица и инструменты -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox MinWidth="235" Height="45" Margin="0,0,8,0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" Padding="10,0"/>
                            <Button Content="⟳"
Command="{Binding RefreshCommand}"
Style="{StaticResource RefreshButton}"
FontSize="30"
MinWidth="40"
Height="42"
Margin="0,0,6,0"/>
                            <Button Content="Поиск"
                                    Command="{Binding LoadCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="100" Margin="0,0,6,0"/>
                            <Button Content="Изменить"
                                    Command="{Binding EditSelectedCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="100" Margin="0,0,6,0"/>
                            <Button Content="Добавить"
                                    Command="{Binding CreateNewCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="100" Margin="0,0,6,0"/>
                            <!-- НОВАЯ КНОПКА ПЕЧАТИ ЭТИКЕТКИ -->
                            <Button Content="Печать"
                                    Command="{Binding PrintLabelCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="100" Margin="0,0,6,0"
                              IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}" />
                            <Button Content="Удалить"
                                    Command="{Binding DeleteCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#E74C3C" BorderBrush="#C0392B"
                                    MinWidth="100"
                                    IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}" />
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F7F7"
                                  RowHeight="52">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="130"/>
                                <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="130"/>
                                <DataGridTextColumn Header="Радиометка" Binding="{Binding RfidBaseTag}" Width="140"/>
                                <DataGridTextColumn Header="Ед.изм." Binding="{Binding Unit}" Width="80"/>
                                <DataGridCheckBoxColumn Header="С/Н" Binding="{Binding UseSerialNumbers}" Width="50"/>
                                <DataGridCheckBoxColumn Header="Партии" Binding="{Binding UseBatches}" Width="60"/>
                                <DataGridTextColumn Header="Закупка" Binding="{Binding PurchasePrice, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightAlign}"/>
                                <DataGridTextColumn Header="Розница" Binding="{Binding RetailPrice, StringFormat=N2}" Width="90" ElementStyle="{StaticResource RightAlign}"/>
                                <DataGridCheckBoxColumn Header="Маркир." Binding="{Binding IsMarked}" Width="60"/>
                                <DataGridCheckBoxColumn Header="Ветис" Binding="{Binding IsVet}" Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                            <ProgressBar Height="4" IsIndeterminate="{Binding IsLoading}"
                                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                                       Margin="0,8,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Правая панель: редактирование / создание -->
                    <Border Grid.Column="1" Background="{StaticResource Surface}" CornerRadius="10"
                            Padding="16,16,16,12" Effect="{StaticResource Elevation2}"
                            Visibility="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedItem.Id, StringFormat='Товар №{0}', FallbackValue='Новый товар'}"
                                           Style="{StaticResource HeaderText}" FontSize="18" Margin="0,0,0,12"/>
                                <TextBlock Text="Название *" Margin="0,0,0,3" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Text="{Binding SelectedItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" Margin="0,0,0,12"/>
                                <TextBlock Text="Артикул" Margin="0,0,0,3" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Text="{Binding SelectedItem.Article, Mode=TwoWay}" Height="38" Margin="0,0,0,12"/>
                                <TextBlock Text="Штрихкод" Margin="0,0,0,3" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Text="{Binding SelectedItem.Barcode, Mode=TwoWay}" Height="38" Margin="0,0,0,12"/>
                                <TextBlock Text="Радиометка" Margin="0,0,0,3" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Text="{Binding SelectedItem.RfidBaseTag, Mode=TwoWay}" Height="38" Margin="0,0,0,12"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Закупка" Margin="0,0,0,3" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox Text="{Binding SelectedItem.PurchasePrice, Mode=TwoWay, StringFormat=N2}" Height="38"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Розница" Margin="0,0,0,3" Foreground="{StaticResource TextSecondary}"/>
                                        <TextBox Text="{Binding SelectedItem.RetailPrice, Mode=TwoWay, StringFormat=N2}" Height="38"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="НДС:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondary}"/>
                                    <TextBox Grid.Column="1" Text="{Binding SelectedItem.VatRate, Mode=TwoWay, StringFormat=N1}" Height="38" Width="80" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <CheckBox Content="С/Н" IsChecked="{Binding SelectedItem.UseSerialNumbers, Mode=TwoWay}" Margin="0,0,0,8"/>
                                        <CheckBox Content="Партии" IsChecked="{Binding SelectedItem.UseBatches, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <CheckBox Content="Маркировка" IsChecked="{Binding SelectedItem.IsMarked, Mode=TwoWay}" Margin="0,0,0,8"/>
                                        <CheckBox Content="ВетИС" IsChecked="{Binding SelectedItem.IsVet, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                    <Button Content="Отмена"
                                            Command="{Binding CancelCommand}"
                                            Style="{StaticResource OutlineButton}"
                                            MinWidth="145" Height="42" Margin="0,0,18,0"/>
                                    <Button MinWidth="145" Height="42" Command="{Binding SaveCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Setter Property="Content" Value="Сохранить"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.Id}" Value="0">
                                                        <Setter Property="Content" Value="Создать"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Партии">
                <views:BatchesView DataContext="{Binding BatchesVM}"/>
            </TabItem>

            <TabItem Header="Серийные номера">
                <views:SerialNumbersView DataContext="{Binding SerialNumbersVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>