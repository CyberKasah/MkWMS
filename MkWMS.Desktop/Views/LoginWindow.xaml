<Window x:Class="MkWMS.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MkWMS — Вход"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource Background}">
    <Grid>
        <Border Width="420"
                Padding="50"
                CornerRadius="18"
                Background="{StaticResource Surface}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource Elevation3}">
            <StackPanel>
                <TextBlock Text="MkWMS"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="{StaticResource Primary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Система складского учёта"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>
                <TextBlock Text="Логин"
                           Style="{StaticResource SubHeaderText}"/>
                <Border Margin="0,6,0,20"
                        CornerRadius="8"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        Background="White">
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Padding="14"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="14"/>
                </Border>
                <TextBlock Text="Пароль"
                           Style="{StaticResource SubHeaderText}"/>
                <Border Margin="0,6,0,6"
                        CornerRadius="8"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        Background="White">
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="14"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </Border>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,24">
                    <TextBlock Text="{Binding PasswordToggleText}"
                               Foreground="{StaticResource Primary}"
                               FontSize="13"
                               Cursor="Hand"
                               Margin="0,0,16,0">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding TogglePasswordVisibilityCommand}" />
                        </TextBlock.InputBindings>
                    </TextBlock>
                    <TextBlock Text="Забыли пароль?"
                               Foreground="{StaticResource Primary}"
                               FontSize="13"
                               Cursor="Hand"
                               MouseLeftButtonDown="ForgotPassword_Click"/>
                </StackPanel>
                <Button Content="Войти"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        Height="48"
                        Margin="0,10,0,0"/>
                <ProgressBar IsIndeterminate="{Binding IsBusy}"
                             Height="4"
                             Margin="0,20,0,0"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource Danger}"
                           Margin="0,12,0,0"
                           TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>