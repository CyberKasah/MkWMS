<UserControl x:Class="MkWMS.Desktop.Views.UserControls.AuditLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Width="200" Height="45" Margin="0,0,8,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Padding="10,0"/>
                <Button Content="Поиск"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="75" Margin="0,0,6,0"/>
                <Button Content="Обновить"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Width="90"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedLog, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F7F7"
                      RowHeight="52">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" ElementStyle="{StaticResource CenterText}"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ActionDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="140"/>
                    <DataGridTextColumn Header="Пользователь" Binding="{Binding UserFullName}" Width="180"/>
                    <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="200"/>
                    <DataGridTextColumn Header="Сущность" Binding="{Binding EntityName}" Width="130"/>
                    <DataGridTextColumn Header="ID сущности" Binding="{Binding EntityId}" Width="110" ElementStyle="{StaticResource CenterText}"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <ProgressBar Height="4" IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}" Margin="0,8,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1"
        Background="{StaticResource Surface}"
        CornerRadius="10"
        Padding="16"
        Effect="{StaticResource Elevation2}"
        Visibility="{Binding SelectedLog, Converter={StaticResource NotNullToBool}}"
        Margin="0,0,0,5">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="{Binding SelectedLog.Id, StringFormat='Лог аудита №{0}'}"
                       Style="{StaticResource HeaderText}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>

                    <TextBlock Text="ДЕТАЛИЗАЦИЯ ИЗМЕНЕНИЙ"
                       FontSize="11"
                       FontWeight="Bold"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource TextSecondary}"/>

                    <Separator Background="{StaticResource Border}" Margin="0,10,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="{StaticResource Border}"
                CornerRadius="4">
                    <DataGrid ItemsSource="{Binding SelectedLogDetails}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource Background}"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#FAFAFA"
                      RowHeight="38"
                      Background="{StaticResource Surface}"
                      BorderThickness="0">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Поле"
                                        Binding="{Binding Field}"
                                        Width="1.2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="8,0"/>
                                        <Setter Property="FontWeight" Value="Medium"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Было"
                                        Binding="{Binding Old}"
                                        Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="5,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource ContentTextSecondary}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Стало"
                                        Binding="{Binding New}"
                                        Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="5,0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
