<UserControl x:Class="MkWMS.Desktop.Views.UserControls.WarehousesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             xmlns:services="clr-namespace:MkWMS.Desktop.Services"
             xmlns:views="clr-namespace:MkWMS.Desktop.Views.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <TabControl>

            <TabItem Header="Склады">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="400"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBox Width="200" Height="45" Margin="0,0,8,0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalContentAlignment="Center" Padding="10,0"/>
                            <Button Content="⟳"
Command="{Binding RefreshCommand}"
Style="{StaticResource RefreshButton}"
FontSize="30"
MinWidth="40"
Height="42"
Margin="0,0,6,0"/>
                            <Button Content="Поиск"
                                    Command="{Binding LoadCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="75" Margin="0,0,6,0"/>
                            <Button Content="Изменить"
                                    Command="{Binding EditSelectedCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="90" Margin="0,0,6,0"/>
                            <Button Content="Добавить"
                                    Command="{Binding AddNewCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Width="85" Margin="0,0,6,0"/>
                            <Button Content="Удалить"
                                    Command="{Binding DeleteWarehouseCommand}"
                                    Visibility="{Binding Source={x:Static services:AuthService.Current}, Path=IsAdministrator, Converter={StaticResource BoolToVis}}"
                                    CommandParameter="{Binding SelectedItem}"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#E74C3C" BorderBrush="#C0392B"
                                    Width="80"
                                    IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F7F7"
                                  RowHeight="52">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" ElementStyle="{StaticResource CenterText}"/>
                                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="2*"/>
                                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Margin="0,10,0,0">
                            <ProgressBar Height="4" IsIndeterminate="{Binding IsLoading}"
                                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                                       Margin="0,8,0,0" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>


                    <Border Grid.Column="1" Background="{StaticResource Surface}" CornerRadius="10"
                            Padding="16" Effect="{StaticResource Elevation2}"
                            Visibility="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedItem.Id, StringFormat='Склад №{0}', FallbackValue='Новый склад'}"
                                           Style="{StaticResource HeaderText}"
                                           FontSize="18"
                                           Margin="0,0,0,15"/>

                                <TextBlock Text="Название *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Text="{Binding SelectedItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="40"
                                         Margin="0,0,0,20"/>

                                <TextBlock Text="Адрес" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                                <TextBox Text="{Binding SelectedItem.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="40"
                                         Margin="0,0,0,20"/>

                                <CheckBox Content="Активен"
                                          IsChecked="{Binding SelectedItem.IsActive, Mode=TwoWay}"
                                          Margin="0,0,0,20"
                                          VerticalContentAlignment="Center"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Отмена"
                                            Command="{Binding CancelCommand}"
                                            Style="{StaticResource OutlineButton}"
                                            MinWidth="135" Height="40" Margin="0,0,16,0"/>
                                    <Button MinWidth="135" Height="40" Command="{Binding SaveCommand}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Setter Property="Content" Value="Сохранить"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedItem.Id}" Value="0">
                                                        <Setter Property="Content" Value="Создать"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedItem.Id}" Value="{x:Null}">
                                                        <Setter Property="Content" Value="Создать"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>


            <TabItem Header="Подразделения">
                <views:DepartmentsView DataContext="{Binding DepartmentsVM}"/>
            </TabItem>


            <TabItem Header="Ячейки">
                <views:StorageLocationsView DataContext="{Binding StorageLocationsVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>