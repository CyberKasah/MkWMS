<UserControl x:Class="MkWMS.Desktop.Views.UserControls.BatchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="690*"/>
            <ColumnDefinition Width="71*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск и кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16" Grid.ColumnSpan="2">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" Padding="12" FontSize="14" Margin="0,0,12,0"/>

            <Button Content="Поиск"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Width="100"
                    Margin="0,0,12,0"/>

            <Button Content="Обновить"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource OutlineButton}"
                    Width="100"/>
        </StackPanel>

        <!-- Таблица партий -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Batches}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9F9F9"
                  SelectedItem="{Binding SelectedBatch}" Grid.ColumnSpan="2">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                    Binding="{Binding Id}" 
                                    Width="60" 
                                    ElementStyle="{StaticResource CenterText}"/>

                <DataGridTextColumn Header="Номер партии" 
                                    Binding="{Binding BatchNumber}" 
                                    Width="*"/>

                <DataGridTextColumn Header="Товар ID" 
                                    Binding="{Binding ProductId}" 
                                    Width="80"/>

                <DataGridTextColumn Header="Дата производства" 
                                    Binding="{Binding ProductionDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="140"/>

                <DataGridTextColumn Header="Срок годности" 
                                    Binding="{Binding ExpirationDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="140"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="{Binding IsBusy}"
                     Height="4"
                     Margin="0,20,0,4"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" Grid.ColumnSpan="2"/>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource Danger}"
                   Margin="0,12,0,0"
                   TextAlignment="Center"
                   TextWrapping="Wrap" Grid.ColumnSpan="2"/>
    </Grid>
</UserControl>