﻿<Application x:Class="MkWMS.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             xmlns:viewmodels="clr-namespace:MkWMS.Desktop.ViewModels"
             xmlns:views="clr-namespace:MkWMS.Desktop.Views.UserControls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Главный файл стилей -->
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Конвертеры -->
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <converters:ShowHideConverter x:Key="ShowHideConverter" />
            <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
            <converters:RolesToStringConverter x:Key="RolesToStringConverter" />
            <converters:RoleToVisibilityConverter x:Key="RoleToVisibility" />
            <converters:MultiRoleToVisibilityConverter x:Key="MultiRoleToVis"/>

            <!-- Навигация: ViewModel -> View -->
            <DataTemplate DataType="{x:Type viewmodels:UsersViewModel}">
                <views:UsersView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:ProductsViewModel}">
                <views:ProductsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:WarehousesViewModel}">
                <views:WarehousesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:BatchesViewModel}">
                <views:BatchesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:SerialNumbersViewModel}">
                <views:SerialNumbersView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:DepartmentsViewModel}">
                <views:DepartmentsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:DocumentTypesViewModel}">
                <views:DocumentTypesView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:RolesViewModel}">
                <views:RolesView/>
            </DataTemplate>

            <DataTemplate DataType="{x:Type viewmodels:DocumentsViewModel}">
                <views:DocumentsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:ReportsViewModel}">
                <views:ReportsView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type viewmodels:AuditLogsViewModel}">
                <views:AuditLogsView/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
