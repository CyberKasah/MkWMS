<Window x:Class="MkWMS.Desktop.Views.Dialogs.EditUserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MkWMS.Desktop.Helpers"
        xmlns:conv="clr-namespace:MkWMS.Desktop.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Управление пользователем — MkWMS"
        Height="900" Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Background}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border Background="{StaticResource Surface}"
            CornerRadius="20"
            Margin="20"
            Effect="{StaticResource Elevation3}">

        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter='Добавление нового пользователя|Изменение данных пользователя'}"
                       Style="{StaticResource HeaderText}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource Primary}"
                       Margin="0,0,0,28"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,-10,0" Padding="0,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Логин *" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource InputBorder}" Margin="0,0,0,20">
                        <TextBox Text="{Binding User.Login, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,10" BorderThickness="0" Background="Transparent"
                                 IsReadOnly="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}"/>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Полное имя *" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource InputBorder}" Margin="0,0,0,20">
                        <TextBox Text="{Binding User.FullName, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="12,10" BorderThickness="0" Background="Transparent"/>
                    </Border>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Пароль *" Style="{StaticResource SubHeaderText}"
                               VerticalAlignment="Center" Margin="0,0,0,20"
                               Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}}"/>
                    <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource InputBorder}" Margin="0,0,0,20"
                            Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}}">
                        <PasswordBox Padding="12,10" BorderThickness="0" Background="Transparent"
                                     local:PasswordBoxHelper.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     local:PasswordBoxHelper.BindPassword="True"/>
                    </Border>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Склад" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource InputBorder}" Margin="0,0,0,20">
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding User.WarehouseId, Mode=TwoWay}"
                                  Padding="8" BorderThickness="0" Background="Transparent"/>
                    </Border>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Статус" Style="{StaticResource SubHeaderText}" VerticalAlignment="Center" Margin="0,0,0,20"/>
                    <CheckBox Grid.Row="4" Grid.Column="1" Content="Активен"
                              IsChecked="{Binding User.IsActive, Mode=TwoWay}"
                              VerticalContentAlignment="Center" Margin="0,0,0,20" FontSize="14"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Роли доступа *" Style="{StaticResource SubHeaderText}" VerticalAlignment="Top" Margin="0,8,0,0"/>
                    <Border Grid.Row="5" Grid.Column="1" Background="#F8FAFC" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1" MinHeight="160" Margin="0,0,0,20">
                        <ListBox ItemsSource="{Binding Roles}" BorderThickness="0" Background="Transparent" Padding="8">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Role.Name}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,4" FontSize="14"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>


                    <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                            Background="#F8FAFC" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1"
                            Padding="16" Margin="0,4,0,0"
                            Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}">
                        <StackPanel>
                            <TextBlock Text="{Binding User.Login, StringFormat='Сброс пароля пользователю: {0}'}"
                                       Style="{StaticResource SubHeaderText}" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <TextBlock Text="Новый пароль" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" FontSize="13"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,12">
                                <PasswordBox Padding="12,10" BorderThickness="0" Background="Transparent"
                                             local:PasswordBoxHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             local:PasswordBoxHelper.BindPassword="True"/>
                            </Border>

                            <TextBlock Text="Подтверждение нового пароля" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" FontSize="13"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,12">
                                <PasswordBox Padding="12,10" BorderThickness="0" Background="Transparent"
                                             local:PasswordBoxHelper.BoundPassword="{Binding NewPasswordConfirm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             local:PasswordBoxHelper.BindPassword="True"/>
                            </Border>

                            <TextBlock Text="Ваш пароль (для подтверждения действия)" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4" FontSize="13"/>
                            <Border Style="{StaticResource InputBorder}" Margin="0,0,0,12">
                                <PasswordBox Padding="12,10" BorderThickness="0" Background="Transparent"
                                             local:PasswordBoxHelper.BoundPassword="{Binding AdminConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             local:PasswordBoxHelper.BindPassword="True"/>
                            </Border>

                            <Button Content="Сбросить пароль" Command="{Binding ResetPasswordCommand}"
                                    Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                    Width="200" Height="40" Margin="0,0,0,10"/>

                            <TextBlock Text="{Binding ResetPasswordMessage}"
                                       TextWrapping="Wrap" FontWeight="Medium" FontSize="13"
                                       Visibility="{Binding ResetPasswordMessage, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource Danger}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ResetPasswordSuccess}" Value="True">
                                                <Setter Property="Foreground" Value="#27AE60"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="0,24,0,0">
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,12"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Foreground="{StaticResource Primary}"/>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                           HorizontalAlignment="Center" Margin="0,0,0,12" FontSize="13"
                           FontWeight="Medium" TextWrapping="Wrap" TextAlignment="Center"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}"
                            Style="{StaticResource PrimaryButton}" Width="150" Height="48" Margin="0,0,16,0"
                            FontSize="15" FontWeight="SemiBold"/>
                    <Button Content="Отмена" Command="{Binding CancelCommand}"
                            Style="{StaticResource OutlineButton}" Width="150" Height="48"
                            FontSize="15"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>