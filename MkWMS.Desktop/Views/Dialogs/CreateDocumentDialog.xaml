<Window x:Class="MkWMS.Desktop.Views.Dialogs.CreateDocumentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
        mc:Ignorable="d"
        Title="Создание документа"
        Height="720" Width="1080"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Background}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
        <converters:ItemSumConverter x:Key="ItemSumConverter" />
        <converters:DocumentTotalConverter x:Key="DocumentTotalConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="620"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Добавить позицию" 
                        Command="{Binding AddItemCommand}"
                        Style="{StaticResource PrimaryButton}" 
                        Width="160" Height="40" Margin="0,0,8,0"/>

                <Button Content="Удалить позицию" 
                        Command="{Binding RemoveItemCommand}"
                        CommandParameter="{Binding ElementName=ItemsGrid, Path=SelectedItem}"
                        Style="{StaticResource DangerButton}" 
                        Width="160" Height="40"
                        IsEnabled="{Binding ElementName=ItemsGrid, Path=SelectedItem, Converter={StaticResource NotNullToBool}}"/>
            </StackPanel>

            <DataGrid x:Name="ItemsGrid" Grid.Row="1"
                      ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      RowHeight="48"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F7F7F7">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Товар *" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedValue="{Binding ProductId, Mode=OneWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          IsEnabled="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedValue="{Binding ProductId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Name"
                                          IsDropDownOpen="True"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Кол-во" 
                    Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Цена" Width="100"
                    Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                    ElementStyle="{StaticResource RightAlign}"/>

                    <DataGridTextColumn Header="НДС" Width="100" IsReadOnly="True"
                    Binding="{Binding VatSum, StringFormat=N2}"
                    ElementStyle="{StaticResource RightAlign}"
                    Foreground="{StaticResource TextSecondary}"/>

                    <DataGridTextColumn Header="Сумма" Width="130" IsReadOnly="True"
                                        Binding="{Binding ., Converter={StaticResource ItemSumConverter}}"
                                        ElementStyle="{StaticResource RightAlign}"/>

                    <DataGridTextColumn Header="Сумма с НДС" Width="130" IsReadOnly="True"
                    Binding="{Binding TotalSum, StringFormat=N2}"
                    ElementStyle="{StaticResource RightAlign}"
                    FontWeight="SemiBold"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock Text="Итого:" FontSize="15" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Items, Converter={StaticResource DocumentTotalConverter}}"
                           FontSize="16" FontWeight="Bold" Foreground="{StaticResource Primary}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="{StaticResource Surface}" CornerRadius="10"
                Padding="20" Effect="{StaticResource Elevation2}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Создание документа" Style="{StaticResource HeaderText}" Margin="0,0,0,16"/>

                    <TextBlock Text="Тип документа *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                    <ComboBox ItemsSource="{Binding DocumentTypes}"
                              SelectedValue="{Binding Document.DocumentTypeId, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Height="40" Margin="0,0,0,16"/>

                    <TextBlock Text="Склад *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedValue="{Binding Document.WarehouseId, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Height="40" Margin="0,0,0,16"/>

                    <TextBlock Text="Контрагент" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                    <ComboBox ItemsSource="{Binding Counterparties}"
                              SelectedValue="{Binding Document.CounterpartyId, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              Height="40" Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Внешний №" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding Document.ExternalNumber, Mode=TwoWay}" Height="40"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Внешняя дата" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                            <DatePicker SelectedDate="{Binding Document.ExternalDate, Mode=TwoWay}" Height="40"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Комментарий" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding Document.Comment, Mode=TwoWay}" Height="80"
                             TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                               Margin="0,0,0,16" TextAlignment="Center" TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NotNullToBool}}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" 
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource OutlineButton}" 
                                MinWidth="180" Height="42" Margin="0,0,16,0" Cursor="Hand"/>

                        <Button Content="Создать" 
                                Command="{Binding SaveCommand}"
                                MinWidth="180" Height="42" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <ProgressBar Height="4" Margin="0,12,0,0" IsIndeterminate="{Binding IsLoading}"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>