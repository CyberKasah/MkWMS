<UserControl x:Class="MkWMS.Desktop.Views.UserControls.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск и кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="250" Padding="12" FontSize="14" Margin="0,0,12,0"/>

            <Button Content="Поиск"
                    Command="{Binding LoadCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Width="100"
                    Margin="0,0,12,0"/>

            <Button Content="Обновить"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource OutlineButton}"
                    Width="100"/>
        </StackPanel>

        <!-- Таблица пользователей -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Users}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9F9F9"
                  SelectedItem="{Binding SelectedUser}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" 
                                    Binding="{Binding Id}" 
                                    Width="60" 
                                    ElementStyle="{StaticResource CenterText}"/>

                <DataGridTextColumn Header="Логин" 
                                    Binding="{Binding Login}" 
                                    Width="180"/>

                <DataGridTextColumn Header="ФИО" 
                                    Binding="{Binding FullName}" 
                                    Width="*"/>

                <DataGridCheckBoxColumn Header="Активен" 
                                        Binding="{Binding IsActive}" 
                                        Width="80"/>

                <DataGridTextColumn Header="Дата создания" 
                                    Binding="{Binding CreatedDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="140"/>

                <DataGridTextColumn Header="Склад ID" 
                                    Binding="{Binding WarehouseId}" 
                                    Width="80"/>

                <DataGridTextColumn Header="Роли" 
                                    Binding="{Binding Roles, Converter={StaticResource RolesToStringConverter}}" 
                                    Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус -->
        <ProgressBar Grid.Row="2"
                     IsIndeterminate="{Binding IsBusy}"
                     Height="4"
                     Margin="0,16,0,0"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="{StaticResource Danger}"
                   Margin="0,12,0,0"
                   TextAlignment="Center"
                   TextWrapping="Wrap"/>
    </Grid>
</UserControl>