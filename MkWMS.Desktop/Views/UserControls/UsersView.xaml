<UserControl x:Class="MkWMS.Desktop.Views.UserControls.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             xmlns:views="clr-namespace:MkWMS.Desktop.Views.UserControls"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <TabControl>
            <!-- Вкладка Пользователи -->
            <TabItem Header="Пользователи">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Width="200" Height="45" Margin="0,0,8,0"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalContentAlignment="Center" Padding="10,0"/>
                        <Button Content="Поиск"
                                Command="{Binding LoadCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="75" Margin="0,0,6,0"/>
                        <Button Content="Обновить"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="90" Margin="0,0,6,0"/>
                        <Button Content="Добавить"
                                Command="{Binding OpenEditDialogCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Width="85" Margin="0,0,6,0"/>
                        <Button Content="Изменить"
                                Command="{Binding OpenEditDialogCommand}"
                                CommandParameter="{Binding SelectedItem}"
                                Style="{StaticResource PrimaryButton}"
                                Width="90" Margin="0,0,6,0"
                                IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}"/>
                        <Button Content="Удалить"
                                Command="{Binding DeleteCommand}"
                                CommandParameter="{Binding SelectedItem}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#E74C3C" BorderBrush="#C0392B"
                                Width="80"
                                IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F7F7"
                              RowHeight="52">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"        Binding="{Binding Id}"                  Width="70"   ElementStyle="{StaticResource CenterText}"/>
                            <DataGridTextColumn Header="Логин"     Binding="{Binding Login}"               Width="160"/>
                            <DataGridTextColumn Header="ФИО"       Binding="{Binding FullName}"            Width="*"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}"        Width="90"/>
                            <DataGridTextColumn Header="Создан"    Binding="{Binding CreatedDate, StringFormat=dd.MM.yyyy}" Width="130"/>
                            <DataGridTextColumn Header="Склад"     Binding="{Binding WarehouseName}"      Width="140"/>
                            <DataGridTextColumn Header="Роли"      Binding="{Binding Roles, Converter={StaticResource RolesToStringConverter}}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <ProgressBar Height="4" IsIndeterminate="{Binding IsLoading}"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                                   Margin="0,8,0,0" TextAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка Роли -->
            <TabItem Header="Роли">
                <views:RolesView DataContext="{Binding RolesVM}"/>
            </TabItem>

            <!-- Вкладка Журнал действий -->
            <TabItem Header="Журнал действий">
                <views:AuditLogsView DataContext="{Binding AuditLogsVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>