<Window x:Class="MkWMS.Desktop.Views.Dialogs.PrintLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Печать этикетки"
        Height="718" Width="603"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Background}">

    <Border Width="584"
            Padding="50"
            CornerRadius="18"
            Background="{StaticResource Surface}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Effect="{StaticResource Elevation3}">

        <StackPanel>
            <TextBlock Text="MkWMS"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="{StaticResource Primary}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Печать этикетки товара"
                       FontSize="14"
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <TextBlock Text="Товар"
                       Style="{StaticResource SubHeaderText}"/>

            <Border Margin="0,6,0,20"
                    CornerRadius="8"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Background="White">
                <TextBlock Text="{Binding ProductName}"
                           Padding="14"
                           FontSize="14"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="Штрихкод / Артикул"
                       Style="{StaticResource SubHeaderText}"/>

            <Border Margin="0,6,0,20"
                    CornerRadius="8"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Background="White">
                <TextBlock Text="{Binding Barcode}"
                           Padding="14"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Количество этикеток"
                       Style="{StaticResource SubHeaderText}"/>

            <Border Margin="0,6,0,24"
                    CornerRadius="8"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Background="White">
                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                         Padding="14"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="14"
                         InputScope="Number"/>
            </Border>

            <Button Content="Печать"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding PrintCommand}"
                    Height="48"
                    Margin="0,0,0,12"/>

            <Button Content="Отмена"
                    Style="{StaticResource OutlineButton}"
                    Command="{Binding CancelCommand}"
                    Height="48"/>

            <ProgressBar IsIndeterminate="{Binding IsBusy}"
                         Height="4"
                         Margin="0,20,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource Danger}"
                       Margin="0,12,0,0"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>