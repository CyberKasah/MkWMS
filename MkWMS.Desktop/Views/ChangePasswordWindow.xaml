<Window x:Class="MkWMS.Desktop.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Смена пароля — MkWMS"
        Height="705" Width="505"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Background}">

    <Border Background="{StaticResource Surface}"
            CornerRadius="18"
            Margin="30"
            Effect="{StaticResource Elevation3}">

        <StackPanel Margin="50,40,50,40">

            <TextBlock Text="Смена пароля"
                       Style="{StaticResource HeaderText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <!-- Старый пароль -->
            <TextBlock Text="Старый пароль"
                       Style="{StaticResource SubHeaderText}"/>
            <Border Margin="0,6,0,24"
                    CornerRadius="8"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Background="White">
                <Grid>
                    <PasswordBox x:Name="OldPasswordBox"
                                 Padding="14"
                                 FontSize="15"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PasswordChanged="OldPasswordBox_PasswordChanged"
                                 Visibility="{Binding IsOldPasswordVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                    <TextBox Text="{Binding OldPassword, UpdateSourceTrigger=PropertyChanged}"
                             Padding="14"
                             FontSize="15"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="{Binding IsOldPasswordVisible, Converter={StaticResource BoolToVis}}"/>

                    <Button Command="{Binding ToggleOldPasswordVisibilityCommand}"
                            Width="44" Height="44"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="{Binding IsOldPasswordVisible, Converter={StaticResource ShowHideConverter}}"
                            FontSize="18"/>
                </Grid>
            </Border>

            <!-- Новый пароль -->
            <TextBlock Text="Новый пароль"
                       Style="{StaticResource SubHeaderText}"/>
            <Border Margin="0,6,0,24"
                    CornerRadius="8"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Background="White">
                <Grid>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Padding="14"
                                 FontSize="15"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PasswordChanged="NewPasswordBox_PasswordChanged"
                                 Visibility="{Binding IsNewPasswordVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                    <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"
                             Padding="14"
                             FontSize="15"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="{Binding IsNewPasswordVisible, Converter={StaticResource BoolToVis}}"/>

                    <Button Command="{Binding ToggleNewPasswordVisibilityCommand}"
                            Width="44" Height="44"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="{Binding IsNewPasswordVisible, Converter={StaticResource ShowHideConverter}}"
                            FontSize="18"/>
                </Grid>
            </Border>

            <!-- Подтверждение -->
            <TextBlock Text="Подтвердите новый пароль"
                       Style="{StaticResource SubHeaderText}"/>
            <Border Margin="0,6,0,32"
                    CornerRadius="8"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1"
                    Background="White">
                <Grid>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Padding="14"
                                 FontSize="15"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged"
                                 Visibility="{Binding IsConfirmPasswordVisible, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

                    <TextBox Text="{Binding ConfirmNewPassword, UpdateSourceTrigger=PropertyChanged}"
                             Padding="14"
                             FontSize="15"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="{Binding IsConfirmPasswordVisible, Converter={StaticResource BoolToVis}}"/>

                    <Button Command="{Binding ToggleConfirmPasswordVisibilityCommand}"
                            Width="44" Height="44"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Content="{Binding IsConfirmPasswordVisible, Converter={StaticResource ShowHideConverter}}"
                            FontSize="18"/>
                </Grid>
            </Border>

            <!-- Кнопки -->
            <Button Content="Сменить пароль"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ChangePasswordCommand}"
                    Height="48"
                    FontSize="15"/>

            <Button Content="Отмена"
                    Style="{StaticResource OutlineButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,12,0,0"
                    Height="48"
                    FontSize="15"/>

            <!-- Статус -->
            <ProgressBar IsIndeterminate="{Binding IsLoading}"
                         Height="4"
                         Margin="0,20,0,0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource Danger}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>