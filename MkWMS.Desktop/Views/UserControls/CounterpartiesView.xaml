<UserControl x:Class="MkWMS.Desktop.Views.UserControls.CounterpartiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:NotNullToBoolConverter x:Key="NotNullToBool" />
    </UserControl.Resources>

    <Grid Margin="0,12,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="420"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Левая часть: таблица и инструменты -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <TextBox Width="200" Height="45" Margin="0,0,8,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Padding="10,0"/>
                <Button Content="⟳"
Command="{Binding RefreshCommand}"
Style="{StaticResource RefreshButton}"
FontSize="30"
MinWidth="40"
Height="42"
Margin="0,0,6,0"/>
                <Button Content="Поиск"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="135" Margin="0,0,6,0"/>
                <Button Content="Изменить"
                        Command="{Binding EditSelectedCommand}"
                        Style="{StaticResource PrimaryButton}"
                         MinWidth="135" Margin="0,0,6,0"/>
                <Button Content="Добавить"
                        Command="{Binding CreateNewCommand}"
                        Style="{StaticResource PrimaryButton}"
                         MinWidth="135" Margin="0,0,6,0"/>
                <Button Content="Удалить"
                        Command="{Binding DeleteCommand}"
                        CommandParameter="{Binding SelectedItem}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#E74C3C" BorderBrush="#C0392B"
                         MinWidth="135"
                        IsEnabled="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" AlternatingRowBackground="#F7F7F7"
                      RowHeight="52">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" ElementStyle="{StaticResource CenterText}"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="ИНН" Binding="{Binding INN}" Width="120"/>
                    <DataGridTextColumn Header="КПП" Binding="{Binding KPP}" Width="110"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="2*"/>
                    <DataGridCheckBoxColumn Header="Поставщик" Binding="{Binding IsSupplier}" Width="90"/>
                    <DataGridCheckBoxColumn Header="Клиент" Binding="{Binding IsCustomer}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <ProgressBar Height="4" IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource Danger}"
                           Margin="0,8,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Правая панель: создание / редактирование контрагента -->
        <Border Grid.Column="1" Background="{StaticResource Surface}" CornerRadius="10"
                Padding="16" Effect="{StaticResource Elevation2}"
                Visibility="{Binding SelectedItem, Converter={StaticResource NotNullToBool}}">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedItem.Id, StringFormat='Контрагент №{0}', FallbackValue='Новый контрагент'}"
                               Style="{StaticResource HeaderText}"
                               FontSize="18"
                               Margin="0,0,0,15"/>

                    <!-- Название -->
                    <TextBlock Text="Название *" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding SelectedItem.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             Margin="0,0,0,16"/>

                    <!-- ИНН и КПП в одной строке -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="ИНН" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding SelectedItem.INN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="КПП" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                            <TextBox Text="{Binding SelectedItem.KPP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Height="40"/>
                        </StackPanel>
                    </Grid>

                    <!-- Адрес -->
                    <TextBlock Text="Адрес" Margin="0,0,0,4" Foreground="{StaticResource TextSecondary}"/>
                    <TextBox Text="{Binding SelectedItem.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             Margin="0,0,0,16"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="60"/>

                    <!-- Тип контрагента -->
                    <TextBlock Text="Тип контрагента" Margin="0,0,0,8" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                    <StackPanel Margin="0,0,0,20">
                        <CheckBox Content="Поставщик"
                                  IsChecked="{Binding SelectedItem.IsSupplier, Mode=TwoWay}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Content="Клиент"
                                  IsChecked="{Binding SelectedItem.IsCustomer, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Кнопки -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource OutlineButton}"
                                MinWidth="135" Height="40" Margin="0,0,16,0"/>
                        <Button MinWidth="135" Height="40" Command="{Binding SaveCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="Сохранить"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedItem.Id}" Value="0">
                                            <Setter Property="Content" Value="Создать"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedItem.Id}" Value="{x:Null}">
                                            <Setter Property="Content" Value="Создать"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>