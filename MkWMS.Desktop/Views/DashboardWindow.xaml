<Window x:Class="MkWMS.Desktop.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:MkWMS.Desktop.Converters"
        Title="MkWMS — Складской учёт"
        Height="760"
        Width="1366"
        MinWidth="1024"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource Background}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0"
                Effect="{StaticResource Elevation3}">

            <DockPanel>

                <!-- USER PANEL -->

                <StackPanel DockPanel.Dock="Bottom"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Center">

        

                    <Button Content="Выйти"
                            Style="{StaticResource OutlineButton}"
                            Width="140"
                            Command="{Binding LogoutCommand}"/>

                </StackPanel>


                <!-- NAVIGATION -->

                <StackPanel>

                    <!-- HEADER -->

                    <StackPanel Margin="0,40,0,40"
                                HorizontalAlignment="Center">

                        <TextBlock Text="MkWMS"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Primary}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Система складского учёта"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>

                    </StackPanel>



                    <!-- НАВИГАЦИЯ -->

                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding GoToUsersCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="18" Margin="12,0,14,0"/>
                            <TextBlock Text="Главная" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>


                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding GoToUsersCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="18" Margin="12,0,14,0"/>
                            <TextBlock Text="Пользователи" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>


                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding GoToProductsCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Margin="12,0,14,0"/>
                            <TextBlock Text="Номенклатура" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>


                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding GoToWarehousesCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏬" FontSize="18" Margin="12,0,14,0"/>
                            <TextBlock Text="Склады" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>


                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding GoToDocumentsCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="18" Margin="12,0,14,0"/>
                            <TextBlock Text="Документы" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>


                    <Button Style="{StaticResource SidebarButton}"
                            Command="{Binding GoToReportsCommand}">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="12,0,14,0"/>
                            <TextBlock Text="Отчёты" VerticalAlignment="Center"/>
                        </StackPanel>

                    </Button>

                </StackPanel>

            </DockPanel>

        </Border>



        <!-- MAIN CONTENT -->

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>



            <!-- TOP BAR -->

            <Border Grid.Row="0"
                    Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1"
                    Effect="{StaticResource Elevation1}">

                <Grid Margin="32,0">

                    <TextBlock Text="Добро пожаловать"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Primary}"
                               VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                        <TextBlock Text="{Binding Roles, Converter={StaticResource RolesToStringConverter}, StringFormat='Роль: {0}'}"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,24,0"/>


                    </StackPanel>

                </Grid>

            </Border>



            <!-- WORKSPACE -->

            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentViewModel}"
                            Margin="32"/>

        </Grid>

    </Grid>

</Window>

